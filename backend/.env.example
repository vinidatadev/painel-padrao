# PostgreSQL
DATABASE_URL=postgresql+asyncpg://usuario:senha@host:5432/nome_banco

# Azure AD
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# JWT local — gere um segredo forte: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=troque-por-um-segredo-forte-aqui
JWT_EXPIRE_H=8

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://seudominio.com
